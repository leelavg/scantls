# scantls Configuration

# Deployment Configuration
NAMESPACE=scantls-system              # Namespace for scanner deployment
TARGET_NAMESPACE=.all                 # ".all" for all namespaces, or "ns1,ns2" (comma/space-separated)
SCAN_INTERVAL=0                       # 0=one-shot mode, >0=continuous scanning (seconds between scans)
TIMEOUT=5                             # Timeout per TLS test in seconds
EXCLUDE_NAMESPACES=""                 # Comma-separated namespaces to exclude (only when TARGET_NAMESPACE=.all)
SKIP_PORTS="22,53"                    # Comma-separated ports to skip (non-TLS ports)
IMAGE=ghcr.io/leelavg/scantls:latest  # Container image to use

# TLS Testing Configuration
# Comma-separated values for versions, ciphers, and groups to test
TLS_VERSIONS=tls1.2,tls1.3            # TLS versions to test

# TLS 1.2 Configuration (OpenSSL cipher names)
TLS12_CIPHERS=ECDHE-ECDSA-AES128-GCM-SHA256,ECDHE-ECDSA-AES256-GCM-SHA384,ECDHE-ECDSA-CHACHA20-POLY1305,ECDHE-RSA-AES128-GCM-SHA256,ECDHE-RSA-AES256-GCM-SHA384,ECDHE-RSA-CHACHA20-POLY1305
TLS12_GROUPS=prime256v1,secp384r1,secp521r1,X25519  # Note: prime256v1 is OpenSSL name for P-256

# TLS 1.3 Configuration
TLS13_CIPHERS=TLS_AES_128_GCM_SHA256,TLS_AES_256_GCM_SHA384,TLS_CHACHA20_POLY1305_SHA256
TLS13_GROUPS=prime256v1,secp384r1,secp521r1,X25519,X25519MLKEM768,SecP256r1MLKEM768,SecP384r1MLKEM1024  # Includes Post-Quantum groups